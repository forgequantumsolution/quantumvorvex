# ── Dependencies ──────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Build output ───────────────────────────────────────────────
client/dist/
client/dist-ssr/

# ── Database ───────────────────────────────────────────────────
server/prisma/dev.db
server/prisma/dev.db-journal
server/prisma/dev.db-shm
server/prisma/dev.db-wal
*.db
*.db-*

# ── Environment / Secrets (NEVER commit these) ─────────────────
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example
client/.env
client/.env.*
!client/.env.example
!client/.env.production
.env.local
.env.*.local

# ── Uploads ────────────────────────────────────────────────────
server/uploads/
uploads/

# ── Logs ───────────────────────────────────────────────────────
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── Security scan outputs ──────────────────────────────────────
.secrets.baseline
gitleaks-report.json
semgrep-results.json
trivy-results.json
k6-results.json

# ── OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Coverage ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Prisma generated client ────────────────────────────────────
server/node_modules/.prisma/

# ── Nginx certs (generate locally, never commit) ───────────────
nginx/certs/

# ── Docker ─────────────────────────────────────────────────────
docker-compose.override.yml

.vercel
